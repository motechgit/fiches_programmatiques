# ============================================================
# .env.example — Variables d'environnement (référence)
# Renommer en .env et remplir les valeurs réelles
# Ne jamais committer .env dans git !
# ============================================================

# Application
APP_ENV=production
APP_URL=https://fiches.ujkz.bf
APP_DEBUG=false

# Base de données
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ujkz_fiches
DB_USER=ujkz_user
DB_PASS=votre_mot_de_passe_mysql

# Email
MAIL_FROM=noreply@ujkz.bf
MAIL_FROM_NAME="Fiches Programmatiques UJKZ"
MAIL_SMTP_HOST=mail.ujkz.bf
MAIL_SMTP_PORT=587
MAIL_SMTP_USER=noreply@ujkz.bf
MAIL_SMTP_PASS=votre_mot_de_passe_smtp
